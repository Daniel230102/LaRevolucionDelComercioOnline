<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>La revolución del comercio online</title>
  <!-- Tailwind CSS para utilidades de diseño modernas -->
  <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet" />
  <!-- Bootstrap para componentes como el modal -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    /* Fondo de la página con imagen personalizada */
    body {
      background-image: url('/images/imagen-fondo.jpg');
      background-size: cover;
      background-repeat: no-repeat;
      background-attachment: fixed;
      background-position: center center;
    }
  </style>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center">
    <!-- Recuadro de login centrado -->
    <div class="bg-white p-8 rounded-lg shadow-md w-96">
        <h1 class="text-3xl font-bold text-center mb-6">¡Bienvenido a La Revolución del Comercio Online!</h1>
        
        <!-- Formulario de inicio de sesión -->
        <form action="/iniciar-sesion" method="POST" class="space-y-4">
            <h2 class="text-xl font-semibold text-center">Iniciar sesión</h2>
            
            <!-- Campo de email -->
            <div>
                <label class="block text-gray-700 mb-2">Correo electrónico</label>
                <input type="email" name="email" required 
                    class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-500" />
            </div>

            <!-- Campo de contraseña -->
            <div>
                <label class="block text-gray-700 mb-2">Contraseña</label>
                <input type="password" name="contraseña" required 
                    class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-500" />
            </div>

            <!-- Botón de enviar -->
            <button type="submit" 
                class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition-colors">
                Iniciar sesión
            </button>
        </form>

        <!-- Enlace a registro -->
        <div class="mt-4 text-center">
            <a href="/registro" class="text-blue-600 hover:text-blue-800">¿No estás registrado? Regístrate aquí</a>
        </div>
    </div>

    <% if (typeof mostrarModalRoles !== 'undefined' && mostrarModalRoles) { %>
    <!-- Modal Bootstrap para seleccionar rol si el usuario tiene varios -->
    <div class="modal fade show" id="modalRolesLogin" tabindex="-1" style="display: block; background: rgba(0,0,0,0.5);" aria-modal="true" role="dialog">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Selecciona tu rol</h5>
          </div>
          <div class="modal-body text-center">
            <!-- Botones para cada rol disponible -->
            <form action="/seleccionar-rol" method="POST">
              <% roles.forEach(function(rol) { %>
                <button 
                  type="submit" 
                  name="rol" 
                  value="<%= rol %>" 
                  class="btn btn-primary btn-lg btn-block mb-3">
                  <%= rol.charAt(0).toUpperCase() + rol.slice(1) %>
                </button>
              <% }); %>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Scripts para inicializar el modal de Bootstrap -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      $(document).ready(function() {
        $('#modalRolesLogin').modal({
          backdrop: 'static',
          keyboard: false,
          show: true
        });
      });
    </script>
    <% } %>
</body>
</html>