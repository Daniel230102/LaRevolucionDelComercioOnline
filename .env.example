# Variables de Entorno - EJEMPLO (copiar a .env y rellenar)

# Servidor
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/LaRevolucionDelComercioOnline

# Sesión (generar un string largo y aleatorio)
SESSION_SECRET=cambia_esto_por_un_secreto_seguro

# Stripe (obtener en https://dashboard.stripe.com/)
STRIPE_SECRET_KEY=sk_test_tu_clave_secreta_aqui
STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publica_aqui

# URL base de la aplicación
BASE_URL=http://localhost:3000
